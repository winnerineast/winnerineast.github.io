ff0c\u731b\u5730\u6251\u5411\u8001\u677f\u3002\u8001\u677f\u624b\u91cc\u8fd8\u62ff\u7740\u6fc0\u5149\u7b14\uff0c\u6307\u7740\u6295\u5f71\u5e55\u5e03\u4e0a\u7684\u6570\u636e\u62a5\u8868\uff0c\u5f92\u52b3\u5730\u6323\u624e\u7740\uff0c\u5374\u6839\u672c\u65e0\u6cd5\u963b\u6321\u5c0f\u5f20\u90a3\u75af\u72c2\u7684\u653b\u51fb\u3002\u6211\u773c\u7741\u7741\u5730\u770b\u7740\u5c0f\u5f20\u4e00\u53e3\u54ac\u5728\u8001\u677f\u7684\u8116\u5b50\u4e0a\uff0c\u9c9c\u8840\u55b7\u6d8c\u800c\u51fa\uff0c\u67d3\u7ea2\u4e86\u8001\u677f\u7684\u767d\u886c\u886b\u2026\u2026\n\u90a3\u4e00\u523b\uff0c\u6574\u4e2a\u529e\u516c\u5ba4\u53d8\u6210\u4e86\u4eba\u95f4\u5730\u72f1\u3002\u5c16\u53eb\u58f0\u3001\u54ed\u558a\u58f0\u3001\u640f\u6597\u58f0\uff0c\u6df7\u6742\u7740\u4ee4\u4eba\u4f5c\u5455\u7684\u8840\u8165\u5473\uff0c\u5145\u65a5\u7740\u6574\u4e2a\u7a7a\u95f4\u3002\u6211\u5413\u5f97\u9b42\u98de\u9b44\u6563\uff0c\u6284\u8d77\u684c\u4e0a\u7684\u6c34\u679c\u5200\uff0c\u53d1\u4e86\u75af\u4f3c\u7684\u51b2\u51fa\u529e\u516c\u5ba4\uff0c\u53ea\u60f3\u9003\u79bb\u8fd9\u4e2a\u6050\u6016\u7684\u5730\u65b9\u3002\n\u8d70\u5eca\u91cc\u4e5f\u6324\u6ee1\u4e86\u201c\u75af\u5b50\u201d\uff0c\u4ed6\u4eec\u75af\u72c2\u5730\u8ffd\u9010\u7740\u9003\u7a9c\u7684\u5458\u5de5\uff0c\u5982\u540c\u5730\u72f1\u91cc\u722c\u51fa\u6765\u7684\u6076\u9b3c\uff0c\u773c\u4e2d\u53ea\u6709\u55dc\u8840\u7684\u75af\u72c2\u3002\u6211\u62fc\u547d\u5730\u5954\u8dd1\uff0c\u5fc3\u810f\u5feb\u8981\u8df3\u51fa\u55d3\u5b50\u773c\uff0c\u6050\u60e7\u50cf\u51b0\u51b7\u7684\u86c7\u4e00\u6837\u7f20\u7ed5\u7740\u6211\uff0c\u8ba9\u6211\u51e0\u4e4e\u65e0\u6cd5\u547c\u5438\u3002\n\u6211\u614c\u4e0d\u62e9\u8def\uff0c\u4e00\u5934\u649e\u8fdb\u4e86\u4e00\u95f4\u655e\u5f00\u7740\u95e8\u7684\u529e\u516c\u5ba4\u3002\u91cc\u9762\u7a7a\u65e0\u4e00\u4eba\uff0c\u53ea\u6709\u4e00\u90e8\u901a\u5f80\u7535\u68af\u4e95\u7684\u7ef4\u4fee\u95e8\u865a\u63a9\u7740\uff0c\u4eff\u4f5b\u662f\u9ed1\u6697\u4e2d\u7684\u4e00\u7ebf\u5e0c\u671b\u3002\u6211\u987e\u4e0d\u4e0a\u591a\u60f3\uff0c\u51b2\u8fdb\u53bb\u731b\u5730\u5173\u4e0a\u95e8\uff0c\u5e0c\u671b\u8fd9\u6247\u8584\u8584\u7684\u95e8\u80fd\u963b\u6321\u90a3\u4e9b\u201c\u75af\u5b50\u201d\u3002\n\u4f46\u6211\u5f88\u5feb\u5c31\u7edd\u671b\u5730\u53d1\u73b0\uff0c\u8fd9\u6247\u95e8\u6839\u672c\u6321\u4e0d\u4f4f\u4ed6\u4eec\uff01\u201c\u75af\u5b50\u201d\u4eec\u75af\u72c2\u5730\u649e\u51fb\u7740\u95e8\uff0c\u53d1\u51fa\u9707\u8033\u6b32\u804b\u7684\u54cd\u58f0\uff0c\u4eff\u4f5b\u968f\u65f6\u90fd\u4f1a\u7834\u95e8\u800c\u5165\u3002\u6211\u60ca\u6050\u5730\u540e\u9000\uff0c\u5374\u4e0d\u5c0f\u5fc3\u8e29\u7a7a\uff0c\u6574\u4e2a\u4eba\u6389\u8fdb\u4e86\u9ed1\u6697\u7684\u7535\u68af\u4e95\u91cc\u3002\n\u6211\u91cd\u91cd\u5730\u6454\u5728\u5730\u4e0a\uff0c\u611f\u89c9\u5168\u8eab\u7684\u9aa8\u5934\u90fd\u8981\u6563\u67b6\u4e86\u3002\u6211\u987e\u4e0d\u4e0a\u75bc\u75db\uff0c\u62ac\u5934\u5411\u4e0a\u671b\u53bb\uff0c\u53ea\u89c1\u90a3\u4e9b\u201c\u75af\u5b50\u201d\u6b63\u8db4\u5728\u7535\u68af\u4e95\u8fb9\u7f18\uff0c\u6076\u72e0\u72e0\u5730\u76ef\u7740\u6211\uff0c\u4eff\u4f5b\u5728\u770b\u7740\u5373\u5c06\u5230\u53e3\u7684\u730e\u7269\u3002\n\u6211\u60ca\u9b42\u672a\u5b9a\uff0c\u610f\u8bc6\u5230\u81ea\u5df1\u6389\u8fdb\u4e86\u4e00\u4e2a\u72ed\u7a84\u7684\u5939\u7f1d\u91cc\uff0c\u8eab\u4f53\u5361\u5728\u4e86\u7535\u68af\u4e95\u548c\u5899\u58c1\u4e4b\u95f4\u3002\u8fd8\u597d\u8fd9\u4e2a\u5939\u7f1d\u8db3\u591f\u5bb9\u7eb3\u6211\uff0c\u800c\u4e14\u201c\u75af\u5b50\u201d\u4eec\u4f3c\u4e4e\u591f\u4e0d\u7740\u6211\u3002\u6211\u6682\u65f6\u5b89\u5168\u4e86\uff0c\u4f46\u8fd9\u53ea\u662f\u6682\u65f6\u7684\u3002\n\u6211\u6df1\u5438\u4e00\u53e3\u6c14\uff0c\u52aa\u529b\u8ba9\u81ea\u5df1\u51b7\u9759\u4e0b\u6765\u3002\u6211\u89c2\u5bdf\u4e86\u4e00\u4e0b\u5468\u56f4\u7684\u73af\u5883\uff0c\u53d1\u73b0\u7535\u68af\u4e95\u91cc\u6709\u4e00\u6839\u9508\u8ff9\u6591\u6591\u7684\u94a2\u7f06\uff0c\u4ece\u4e95\u5e95\u4e00\u76f4\u5ef6\u4f38\u5230\u9876\u7aef\u3002\u4e5f\u8bb8\uff0c\u6211\u53ef\u4ee5\u987a\u7740\u5b83\u722c\u4e0a\u53bb\uff1f\n\u6211\u4e0d\u6562\u803d\u6401\uff0c\u5fcd\u7740\u75bc\u75db\uff0c\u624b\u811a\u5e76\u7528\u5730\u6500\u722c\u8d77\u6765\u3002\u94a2\u7f06\u5f88\u6ed1\uff0c\u6211\u7684\u624b\u88ab\u78e8\u7834\u4e86\u76ae\uff0c\u9c9c\u8840\u987a\u7740\u94a2\u7f06\u5f80\u4e0b\u6ef4\u3002\u4f46\u6211\u4e0d\u6562\u505c\u4e0b\u6765\uff0c\u56e0\u4e3a\u6211\u77e5\u9053\uff0c\u53ea\u8981\u6211\u7a0d\u6709\u677e\u61c8\uff0c\u5c31\u4f1a\u6389\u4e0b\u53bb\uff0c\u6210\u4e3a\u90a3\u4e9b\u201c\u75af\u5b50\u201d\u7684\u98df\u7269\u3002\n\u7ecf\u8fc7\u4e00\u756a\u8270\u96be\u7684\u6500\u722c\uff0c\u6211\u7ec8\u4e8e\u722c\u5230\u4e86\u7535\u68af\u4e95\u7684\u9876\u7aef\u3002\u6211\u63a8\u5f00\u9876\u5c42\u7684\u5b89\u5168\u95e8\uff0c\u722c\u4e86\u51fa\u53bb\u3002\u7ad9\u5728\u516c\u53f8\u6240\u5728\u7684\u529e\u516c\u697c\u9876\uff0c\u4fef\u77b0\u6574\u4e2aCBD\uff0c\u773c\u524d\u7684\u666f\u8c61\u8ba9\u6211\u9707\u60ca\uff1a\u6574\u5ea7\u57ce\u5e02\u90fd\u7b3c\u7f69\u5728\u4e00\u7247\u672b\u65e5\u7684\u9634\u973e\u4e4b\u4e2d\uff0c\u8857\u9053\u4e0a\u6324\u6ee1\u4e86\u201c\u75af\u5b50\u201d\uff0c\u4ed6\u4eec\u5728\u75af\u72c2\u5730\u6e38\u8361\uff0c\u5bfb\u627e\u7740\u65b0\u7684\u730e\u7269\u3002\n\u6211\u5012\u5438\u4e00\u53e3\u51c9\u6c14\uff0c\u539f\u6765\u8fd9\u5c31\u662f\u672b\u65e5\u3002\u6211\u65e0\u529b\u5730\u5750\u5728\u5730\u4e0a\uff0c\u4e00\u65f6\u4e4b\u95f4\uff0c\u7adf\u611f\u5230\u65e0\u6bd4\u7684\u604d\u60da\u548c\u7edd\u671b\u3002\n\u591c\u5e55\u964d\u4e34\uff0c\u4e5d\u6708\u7684\u665a\u98ce\u5e26\u7740\u4e00\u4e1d\u51c9\u610f\uff0c\u62c2\u8fc7\u6211\u7684\u8138\u5e9e\uff0c\u5374\u65e0\u6cd5\u9a71\u6563\u6211\u5fc3\u4e2d\u7684\u6050\u60e7\u548c\u5bd2\u610f\u3002\u6211\u5750\u5728\u529e\u516c\u697c\u7684\u9876\u697c\uff0c\u671b\u7740\u8fd9\u5ea7\u5df2\u7ecf\u6ca6\u9677\u7684\u57ce\u5e02\uff0c\u5fc3\u4e2d\u4e94\u5473\u6742\u9648\u3002\n\u8857\u9053\u4e0a\uff0c\u66fe\u7ecf\u7199\u7199\u6518\u6518\u7684\u4eba\u7fa4\u53d8\u6210\u4e86\u55dc\u8840\u7684\u602a\u7269\uff0c\u4ed6\u4eec\u7684\u5636\u543c\u58f0\u3001\u60e8\u53eb\u58f0\uff0c\u5982\u540c\u6765\u81ea\u5730\u72f1\u7684\u54c0\u568e\uff0c\u5728\u591c\u7a7a\u4e2d\u56de\u8361\u3002\u5076\u5c14\u4f20\u6765\u8f66\u8f86\u7684\u649e\u51fb\u58f0\u3001\u7206\u70b8\u58f0\uff0c\u50cf\u662f\u672b\u65e5\u7684\u4e27\u949f\uff0c\u4e00\u4e0b\u4e0b\u6572\u51fb\u7740\u6211\u7684\u5fc3\u623f\u3002\u7a7a\u6c14\u4e2d\u5f25\u6f2b\u7740\u6d53\u91cd\u7684\u8840\u8165\u5473\uff0c\u4ee4\u4eba\u4f5c\u5455\u3002\n\u6211\u52aa\u529b\u8ba9\u81ea\u5df1\u51b7\u9759\u4e0b\u6765\u3002\u6050\u614c\u548c\u7edd\u671b\u4e8e\u4e8b\u65e0\u8865\uff0c\u6211\u5fc5\u987b\u5c3d\u5feb\u5236\u5b9a\u751f\u5b58\u8ba1\u5212\u3002\n\u9996\u5148\uff0c\u6211\u9700\u8981\u627e\u5230\u4e00\u4e2a\u5b89\u5168\u7684\u907f\u96be\u6240\u3002\u8fd9\u680b\u529e\u516c\u697c\u663e\u7136\u4e0d\u5408\u9002\uff0c\u8fd9\u91cc\u4eba\u5458\u5bc6\u96c6\uff0c\u53d8\u6210\u201c\u75af\u5b50\u201d\uff0c\u4e0d\uff0c\u5e94\u8be5\u662f\u4e27\u5c38\uff08\u6211\u5728\u65e0\u6570\u7f8e\u5267\u91cc\u9762\u770b\u8fc7\u7684\uff09\u7684\u6570\u91cf\u592a\u591a\uff0c\u8fd9\u91cc\u65e0\u6cd5\u4fdd\u8bc1\u6211\u957f\u671f\u7684\u5b89\u5168\u3002\u800c\u4e14\uff0c\u8fd9\u91cc\u5e76\u6ca1\u6709\u5145\u8db3\u7684\u98df\u7269\u548c\u6c34\uff0c\u6211\u9700\u8981\u4e00\u4e2a\u66f4\u9690\u853d\u3001\u66f4\u6613\u5b88\u96be\u653b\u7684\u5730\u65b9\u3002\n\u6211\u73af\u987e\u56db\u5468\uff0c\u76ee\u5149\u843d\u5728\u4e86\u8fdc\u5904\u7684\u4e00\u5ea7\u5c71\u4e0a\u3002\u5c71\u4e0a\u6811\u6728\u8302\u5bc6\uff0c\u5730\u5f62\u590d\u6742\uff0c\u6216\u8bb8\u53ef\u4ee5\u6210\u4e3a\u6211\u7684\u85cf\u8eab\u4e4b\u6240\u3002\n\u4f46\u662f\uff0c\u5982\u4f55\u5230\u8fbe\u90a3\u91cc\u5462\uff1f\u5148\u4e0d\u8981\u8bf4\u6211\u4e0d\u53ef\u80fd\u7a7f\u8d8a\u6ee1\u662f\u4e27\u5c38\u7684\u8857\u9053\uff0c\u5c31\u8fde\u8fd9\u680b\u5145\u6ee1\u4e27\u5c38\u7684\u529e\u516c\u697c\uff0c\u6211\u90fd\u4e0d\u77e5\u9053\u8981\u5982\u4f55\u79bb\u5f00\u3002\n\u8fd9\u65f6\uff0c\u6211\u626d\u8fc7\u5934\uff0c\u770b\u89c1\u79bb\u6211\u5750\u7740\u4e0d\u5230\u5341\u7c73\u7684\u4e00\u4e2a\u9ad8\u53f0\u4e0a\uff0c\u505c\u7740\u4e00\u67b6\u5929\u84dd\u8272\u7684\u7f57\u5bbe\u900aR44 Raven II\u578b\u76f4\u5347\u673a\u3002\u5929\u65e0\u7edd\u4eba\u4e4b\u8def\uff0c\u8fd9\u4e0d\u5c31\u662f\u6211\u4eec\u6d77\u5f52\u8001\u677f\u7684\u4ea4\u901a\u5de5\u5177\u5417\uff1f\u60f3\u5230\u8001\u677f\uff0c\u6211\u8fd8\u60f3\u5230\u4eca\u5929\u65e9\u4e0a\u4ed6\u4e00\u8fdb\u529e\u516c\u5ba4\u5c31\u548c\u6211\u8bf4\uff1a\u201cAaron\uff0c\u54b1\u4eec\u52a0\u628a\u52b2\uff0c\u628a\u8fd9\u4e2a\u6296\u97f3app\u53d1\u5e03\u4e86\uff0c\u660e\u5e74\u6211\u5e26\u4f60\u53bb\u7eb3\u65af\u8fbe\u514b\u6572\u949f\u3002\u201d \u73b0\u5728\u7684\u4ed6\uff0c\u5e94\u8be5\u548c\u5176\u5b83\u7684\u4e27\u5c38\u5728\u4e0b\u9762\u7684\u529e\u516c\u697c\u91cc\u6e38\u8361\uff0c\u8ffd\u9010\u548c\u6355\u730e\u8fd8\u6d3b\u7740\u7684\u4eba\u5427\u3002\n\u6211\u66fe\u7ecf\u5750\u8fc7\u8001\u677f\u7684\u98de\u673a\uff0c\u542c\u4ed6\u5439\u5618\u8fc7\u4ed6\u7684\u98de\u884c\u6280\u672f\u3002\u53bb\u5e74\u4ed6\u7b2c\u4e00\u6b21\u7ed9\u6211\u53d1\u4e86\u8d85\u8fc7\u4e00\u767e\u4e07\u7684\u5e74\u7ec8\u5956\u7684\u65f6\u5019\uff0c\u6211\u8fd8\u81a8\u80c0\u8fc7\uff0c\u68a6\u60f3\u4e70\u4e00\u67b6\u98de\u673a\uff0c\u751a\u81f3\u8fd8\u7ffb\u9605\u8fc7\u4e00\u4e9b\u76f4\u5347\u673a\u9a7e\u9a76\u7684\u5165\u95e8\u4e66\u7c4d\u3002\u6216\u8bb8\uff0c\u6211\u53ef\u4ee5\u8bd5\u8bd5\uff1f\u6211\u77e5\u9053\u8fd9\u5f88\u75af\u72c2\uff0c\u4f46\u6211\u522b\u65e0\u9009\u62e9\u3002\n\u6211\u7ad9\u8d77\u6765\uff0c\u8dd1\u8fc7\u53bb\uff0c\u673a\u8231\u95e8\u6ca1\u6709\u9501\uff0c\u6211\u4e00\u628a\u62c9\u5f00\u8231\u95e8\uff0c\u722c\u8fdb\u76f4\u5347\u673a\uff0c\u5f00\u59cb\u56de\u5fc6\u90a3\u4e9b\u4e66\u7c4d\u4e0a\u7684\u5185\u5bb9\u548c\u8001\u677f\u7684\u64cd\u4f5c\u6d41\u7a0b\u3002\n\u9996\u5148\uff0c\u6253\u5f00\u603b\u7535\u6e90\u5f00\u5173\uff0c\u68c0\u67e5\u71c3\u6cb9\u8868\u548c\u53d1\u52a8\u673a\u4eea\u8868\u3002\u63a5\u7740\uff0c\u6253\u5f00\u6cb9\u6c14\u5206\u79bb\u5668\u5f00\u5173\uff0c\u542f\u52a8\u53d1\u52a8\u673a\uff0c\u7b49\u8f6c\u901f\u7a33\u5b9a\u540e\u518d\u6253\u5f00\u4e3b\u65cb\u7ffc\u5239\u8f66\u3002\u6700\u540e\uff0c\u8f7b\u63a8\u603b\u8ddd\u6746\uff0c\u76f4\u5347\u673a\u5c45\u7136\u7f13\u7f13\u5347\u7a7a\u4e86\u2026\u2026\n\u6211\u7d27\u5f20\u5f97\u624b\u5fc3\u5192\u6c57\uff0c\u6bcf\u4e00\u4e2a\u6b65\u9aa4\u90fd\u5c0f\u5fc3\u7ffc\u7ffc\uff0c\u751f\u6015\u51fa\u4e00\u70b9\u5dee\u9519\u3002\n\u5c31\u5728\u6211\u4ee5\u4e3a\u4e00\u5207\u987a\u5229\u7684\u65f6\u5019\uff0c\u610f\u5916\u53d1\u751f\u4e86\uff01\u7531\u4e8e\u64cd\u4f5c\u4e0d\u719f\u7ec3\uff0c\u6211\u731b\u5730\u63a8\u4e86\u4e00\u4e0b\u603b\u8ddd\u6746\uff0c\u76f4\u5347\u673a\u7a81\u7136\u6025\u901f\u4e0a\u5347\uff0c\u7136\u540e\u53c8\u731b\u5730\u5411\u4e00\u4fa7\u503e\u659c\u3002\n\u6211\u60ca\u614c\u5931\u63aa\uff0c\u8fde\u5fd9\u8c03\u6574\u64cd\u7eb5\u6746\uff0c\u4f46\u76f4\u5347\u673a\u5374\u50cf\u4e00\u5339\u8131\u7f30\u7684\u91ce\u9a6c\uff0c\u5728\u7a7a\u4e2d\u6447\u6446\u4e0d\u5b9a\u3002\u6211\u611f\u89c9\u81ea\u5df1\u7684\u5fc3\u810f\u90fd\u8981\u8df3\u51fa\u6765\u4e86\uff0c\u8033\u8fb9\u547c\u547c\u7684\u98ce\u58f0\u548c\u87ba\u65cb\u6868\u7684\u8f70\u9e23\u58f0\u6df7\u6742\u5728\u4e00\u8d77\uff0c\u773c\u524d\u7684\u4e00\u5207\u90fd\u5728\u65cb\u8f6c\u3002\n\u6211\u62fc\u547d\u5730\u56de\u5fc6\u7740\u64cd\u4f5c\u8981\u9886\uff0c\u52aa\u529b\u63a7\u5236\u7740\u76f4\u5347\u673a\u3002\u201c\u62c9\u8d77\u6765\uff0c\u62c9\u8d77\u6765\uff01\u201d\u6211 \u5728\u5fc3\u91cc\u62fc\u547d\u5730\u558a\u7740\u3002\n\u7ec8\u4e8e\uff0c\u5728\u7ecf\u5386\u4e86\u51e0\u6b21\u60ca\u9669\u7684\u4fef\u51b2\u548c\u6447\u6446\u4e4b\u540e\uff0c\u6211\u9010\u6e10\u638c\u63e1\u4e86\u5e73\u8861\uff0c\u76f4\u5347\u673a\u4e5f\u6062\u590d\u4e86\u5e73\u7a33\uff0c\u5728\u7a7a\u4e2d\u60ac\u505c\u7740\u3002\u6211\u957f\u8212\u4e00\u53e3\u6c14\uff0c\u64e6\u4e86\u64e6\u989d\u5934\u7684\u51b7\u6c57\u3002\n\u8fd9\u65f6\uff0c\u697c\u4e0b\u4f20\u6765\u4e00\u9635\u9a9a\u52a8\u3002\u6211\u63a2\u5934\u671b\u53bb\uff0c\u53ea\u89c1\u4e00\u5927\u7fa4\u201c\u75af\u5b50\u201d\u88ab\u76f4\u5347\u673a\u7684\u566a\u97f3\u5438\u5f15\uff0c\u6b63\u671d\u7740\u8fd9\u680b\u5927\u697c\u6d8c\u6765\u3002\u770b\u6765\uff0c\u6211\u5f97\u52a0\u5feb\u901f\u5ea6\u4e86\u3002\n\u6211\u4e00\u63a8\u9a7e\u9a76\u6746\uff0c\u9a7e\u9a76\u7740\u76f4\u5347\u673a\uff0c\u671d\u7740\u8fdc\u5904\u7684\u5c71\u98de\u53bb\u3002\u591c\u8272\u8d8a\u6765\u8d8a\u6df1\uff0c\u57ce\u5e02\u5728\u6211\u811a\u4e0b\u6e10\u6e10\u7f29\u5c0f\uff0c\u6700\u7ec8\u6d88\u5931\u5728\u9ed1\u6697\u4e2d\u3002\n\u6211\u5750\u5728\u9a7e\u9a76\u4f4d\u4e0a\uff0c\u4f9d\u7136\u7d27\u5f20\u5f97\u624b\u5fc3\u5192\u6c57\uff0c\u5c0f\u5fc3\u7ffc\u7ffc\u5730\u7ef4\u6301\u7740\u98de\u673a\u7684\u5e73\u8861\u3002\u4f46\u5c31\u5728\u8fd9\u65f6\uff0c\u610f\u5916\u518d\u6b21\u53d1\u751f\u4e86\uff01\u6216\u8bb8\u662f\u592a\u8fc7\u7d27\u5f20\uff0c\u6211\u7684\u624b\u8098\u4e0d\u5c0f\u5fc3\u78b0\u5230\u4e86\u4e00\u4e2a\u6309\u94ae\u3002\n\u201c\u7cdf\u7cd5\uff01\u201d\u6211\u8ba4\u51fa\u90a3\u662f\u81ea\u52a8\u9a7e\u9a76\u4eea\u7684\u6309\u94ae\uff0c\u4e4b\u524d\u542c\u8001\u677f\u5439\u5618\u8fc7\u5b83\u7684\u4fbf\u6377\u6027\uff0c\u8bf4\u53ea\u8981\u8bbe\u5b9a\u597d\u76ee\u7684\u5730\uff0c\u76f4\u5347\u673a\u5c31\u80fd\u81ea\u52a8\u98de\u884c\u3002\n\u6211\u8fd8\u6ca1\u6765\u5f97\u53ca\u53cd\u5e94\uff0c\u76f4\u5347\u673a\u5c31\u731b\u5730\u5411\u524d\u7a9c\u4e86\u51fa\u53bb\uff0c\u901f\u5ea6\u6bd4\u6211\u624b\u52a8\u64cd\u63a7\u65f6\u5feb\u5f97\u591a\u3002\n\u201c\u600e\u4e48\u56de\u4e8b\uff1f\u201d\u6211\u614c\u4e71\u5730\u67e5\u770b\u4eea\u8868\u76d8\uff0c\u53d1\u73b0\u822a\u7ebf\u6307\u793a\u706f\u4eae\u4e86\u8d77\u6765\uff0c\u6307\u5411\u7684\u65b9\u5411\u6b63\u662f\u8001\u677f\u7684\u5c71\u95f4\u522b\u5885\u3002\n\u201c\u539f\u6765\u662f\u81ea\u52a8\u5bfc\u822a\uff01\u201d\u6211\u8fd9\u624d\u660e\u767d\u8fc7\u6765\uff0c\u8001\u677f\u4e4b\u524d\u8bbe\u5b9a\u597d\u7684\u822a\u7ebf\u76ee\u7684\u5730\u5c31\u662f\u4ed6\u7684\u522b\u5885\u3002\n\u6211\u5fc3\u4e2d\u4e00\u9635\u72c2\u559c\uff0c\u770b\u6765\u6211\u4e0d\u7528\u8d39\u529b\u9a7e\u9a76\u4e86\uff0c\u76f4\u5347\u673a\u53ef\u4ee5\u81ea\u52a8\u628a\u6211\u5e26\u5230\u76ee\u7684\u5730\uff01\n\u4f46\u6211\u9ad8\u5174\u5f97\u592a\u65e9\u4e86\u3002\u7531\u4e8e\u6211\u4e4b\u524d\u614c\u4e71\u4e2d\u8c03\u6574\u8fc7\u98de\u884c\u9ad8\u5ea6\uff0c\u73b0\u5728\u7684\u822a\u7ebf\u6bd4\u6b63\u5e38\u60c5\u51b5\u4e0b\u4f4e\u4e86\u4e0d\u5c11\u3002\n\u201c\u8981\u649e\u4e0a\u4e86\uff01\u201d\u6211\u60ca\u6050\u5730\u53d1\u73b0\u76f4\u5347\u673a\u6b63\u671d\u7740\u5c71\u5761\u4e0a\u7684\u6811\u6797\u98de\u53bb\u3002\n\u6211\u62fc\u547d\u5730\u60f3\u8981\u89e3\u9664\u81ea\u52a8\u9a7e\u9a76\uff0c\u91cd\u65b0\u63a7\u5236\u76f4\u5347\u673a\uff0c\u4f46\u5df2\u7ecf\u6765\u4e0d\u53ca\u4e86\u3002\n\u201c\u8f70\u201d\u7684\u4e00\u58f0\u5de8\u54cd\uff0c\u76f4\u5347\u673a\u649e\u65ad\u4e86\u6570\u68f5\u5927\u6811\u540e\uff0c\u91cd\u91cd\u5730\u6454\u5728\u4e86\u5c71\u5761\u4e0a\u2026\u2026\n\u6211\u8ff7\u8ff7\u7cca\u7cca\u5730\u9192\u8f6c\u8fc7\u6765\uff0c\u4e5d\u6708\u7684\u5c71\u6797\u7559\u5b58\u4e86\u590f\u65e5\u7684\u5168\u90e8\u70ed\u91cf\uff0c\u8ba9\u6211\u611f\u89c9\u6c57\u6c34\u6253\u6e7f\u4e86\u9002\u5408\u4e8e\u7a7a\u8c03\u623f\u7684\u957f\u8896\u886c\u886b\u548c\u4f11\u95f2\u897f\u88e4\uff0c\u7d27\u7d27\u8d34\u5728\u6211\u7684\u8eab\u4e0a\uff0c\u8ba9\u4eba\u900f\u4e0d\u8fc7\u6c14\u6765\u3002\n\u6211\u8bd5\u56fe\u611f\u53d7\u6211\u81ea\u5df1\u7684\u8eab\u4f53\uff0c\u5e76\u4e3e\u8d77\u5de6\u624b\u89c2\u5bdf\u662f\u5426\u5b8c\u597d\u3002\u6211\u53d1\u73b0\u6211\u4ef0\u9762\u671d\u4e0a\u8eba\u5728\u4e00\u7247\u704c\u6728\u4e4b\u4e0a\uff0c\u8eab\u4e0a\u5c45\u7136\u6ca1\u6709\u4efb\u4f55\u75bc\u75db\uff0c\u4e5f\u53ef\u4ee5\u6d3b\u52a8\u81ea\u5982\u3002\n\u6211\u5c1d\u8bd5\u5750\u4e86\u8d77\u6765\uff0c\u53d1\u73b0\u8fd9\u6d53\u5bc6\u7684\u704c\u6728\u5982\u540c\u4e00\u4e2a\u539a\u539a\u7684\u57ab\u5b50\u6551\u4e86\u6211\u4e00\u547d\u3002\u76f4\u5347\u673a\u5728\u79bb\u6211\u5927\u7ea6\u4e09\u5341\u7c73\u8fdc\u7684\u5730\u65b9\u534a\u57cb\u5728\u5c71\u5761\u4e0a\uff0c\u96f6\u661f\u7684\u706b\u82d7\u548c\u9ed1\u70df\u4f9d\u7136\u56f4\u7ed5\u7740\u6b8b\u9ab8\uff0c\u822a\u7a7a\u67f4\u6cb9\u7684\u5473\u9053\u5728\u7a7a\u6c14\u4e2d\u5f25\u6f2b\u3002\u6211\u62ac\u5934\u770b\u4e86\u770b\u56db\u5468\uff0c\u5f88\u5feb\u6211\u5c31\u770b\u89c1\u8001\u677f\u7684\u522b\u5885\u4ece\u6811\u6797\u540e\u9732\u51fa\u5c16\u5c16\u7684\u9876\uff0c\u9876\u4e0a\u6709\u4e00\u9897\u6807\u5fd7\u706f\u4e00\u95ea\u4e00\u95ea\uff0c\u5c31\u5728\u6211\u8eab\u540e\u5927\u7ea6\u4e00\u767e\u7c73\u7684\u5730\u65b9\u3002\n\u7b49\u6211\u91cd\u65b0\u638c\u63a7\u6574\u4e2a\u8eab\u4f53\u7684\u65f6\u5019\uff0c\u6211\u8270\u96be\u5730\u4ece\u539a\u539a\u7684\u704c\u6728\u4e0a\u9762\u632a\u4e0b\u6765\uff0c\u4ece\u5730\u4e0a\u6361\u8d77\u4e00\u6839\u5982\u68d2\u7403\u68cd\u7c97\u7684\u6811\u679d\uff0c\u62ff\u5728\u624b\u91cc\u6325\u52a8\u4e86\u51e0\u4e0b\uff0c\u8fd8\u633a\u8d81\u624b\uff0c\u7136\u540e\u4e00\u6b65\u4e00\u6b65\u8d70\u5411\u8001\u677f\u7684\u522b\u5885\u3002\n\u8001\u677f\u7684\u522b\u5885\u662f\u5178\u578b\u7684\u7f8e\u5f0f\u522b\u5885\uff0cT\u578b\u5e03\u5c40\uff0c\u4e94\u5c42\u4e3b\u697c\u52a0\u4e0a\u5782\u76f4\u65b9\u5411\u4e24\u5c42\u88d9\u697c\uff0c\u5927\u95e8\u5f00\u5728\u4e3b\u697c\u7684\u9876\u7aef\uff0c\u662f\u4e00\u6247\u539a\u91cd\u7684\u6843\u6728\u95e8\uff0c\u95e8\u5eca\u4e0a\u6709\u4e00\u76cf\u591c\u706f\u4eae\u7740\u3002\u6211\u5148\u89c2\u5bdf\u4e86\u4e00\u4e0b\u6bcf\u4e00\u6247\u7a97\u6237\uff0c\u6240\u6709\u7684\u623f\u95f4\u90fd\u662f\u9ed1\u7684\uff0c\u4f3c\u4e4e\u6ca1\u6709\u4eba\u3002\u6211\u5370\u8c61\u91cc\u8001\u677f\u7684\u5bb6\u4eba\u4e00\u822c\u90fd\u4f4f\u5728\u57ce\u91cc\u7684\u516c\u5bd3\uff0c\u5468\u672b\u624d\u4f1a\u6765\u522b\u5885\uff0c\u6253\u626b\u6e05\u6d01\u7684\u963f\u59e8\u548c\u56ed\u4e01\u4e5f\u90fd\u4e0d\u4f4f\u5728\u522b\u5885\u91cc\uff0c\u53ea\u6709\u4e00\u4e2a\u770b\u95e8\u7684\u8001\u5934\u4f4f\u5728\u88d9\u697c\u3002\u4e8e\u662f\uff0c\u6211\u8f7b\u624b\u8f7b\u811a\u5730\u6cbf\u7740\u522b\u5885\u7684\u5916\u5899\u671d\u88d9\u697c\u6478\u8fc7\u53bb\u3002\n\u6211\u5c4f\u4f4f\u547c\u5438\uff0c\u8f7b\u624b\u8f7b\u811a\u5730\u7ed5\u5230\u88d9\u697c\u7684\u4e00\u4fa7\u3002\u8fd9\u91cc\u6709\u4e00\u6247\u5c0f\u5c0f\u7684\u7a97\u6237\uff0c\u6b63\u5bf9\u7740\u770b\u95e8\u8001\u5934\u7684\u5c0f\u5c4b\u3002\u6211\u5c0f\u5fc3\u5730\u63a2\u5934\u671b\u53bb\uff0c\u501f\u7740\u5fae\u5f31\u7684\u6708\u5149\uff0c\u6211\u770b\u5230\u8001\u5934\u6b63\u80cc\u5bf9\u7740\u6211\uff0c\u5728\u72ed\u5c0f\u7684\u623f\u95f4\u91cc\u6765\u56de\u8e31\u6b65\u3002\u4ed6\u4f5d\u507b\u7740\u8eab\u5b50\uff0c\u52a8\u4f5c\u50f5\u786c\uff0c\u5634\u91cc\u53d1\u51fa\u542b\u7cca\u4e0d\u6e05\u7684\u5495\u54dd\u58f0\uff0c\u548c\u4e4b\u524d\u5224\u82e5\u4e24\u4eba\u3002\n\u770b\u6765\uff0c\u4ed6\u4e5f\u53d8\u6210\u4e86\u90a3\u4e9b\u201c\u75af\u5b50\u201d\u4e2d\u7684\u4e00\u5458\u3002\n\u6211\u5fc3\u91cc\u4e00\u6c89\uff0c\u63e1\u7d27\u4e86\u624b\u4e2d\u7684\u6811\u679d\u3002\u6211\u5fc5\u987b\u5f97\u60f3\u529e\u6cd5\u9664\u6389\u4ed6\uff0c\u5426\u5219\u6211\u65e0\u6cd5\u5b89\u5fc3\u8fdb\u5165\u522b\u5885\u3002\n\u6211\u73af\u987e\u56db\u5468\uff0c\u53d1\u73b0\u5c0f\u5c4b\u65c1\u8fb9\u5806\u653e\u7740\u4e00\u4e9b\u6742\u7269\uff0c\u6709\u5e9f\u5f03\u7684\u6728\u677f\u3001\u7834\u65e7\u7684\u8f6e\u80ce\uff0c\u8fd8\u6709\u4e00\u6346\u6346\u7684\u7ef3\u5b50\u3002\u4e00\u4e2a\u8ba1\u5212\u5728\u6211\u7684\u8111\u6d77\u4e2d\u9010\u6e10\u6210\u5f62\u3002\n\u6211\u51b3\u5b9a\u5148\u628a\u8001\u5934\u5f15\u51fa\u6765\u3002\u6211\u6361\u8d77\u4e00\u5757\u77f3\u5934\uff0c\u7528\u529b\u6254\u5411\u5c0f\u5c4b\u7684\u53e6\u4e00\u4fa7\u3002\u77f3\u5934\u649e\u51fb\u5728\u5899\u58c1\u4e0a\uff0c\u53d1\u51fa\u201c\u7830\u201d\u7684\u4e00\u58f0\u54cd\u3002\n\u8001\u5934\u542c\u5230\u52a8\u9759\uff0c\u731b\u5730\u8f6c\u8fc7\u8eab\uff0c\u671d\u7740\u58f0\u97f3\u4f20\u6765\u7684\u65b9\u5411\u8d70\u53bb\u3002\u6211\u8d76\u7d27\u8eb2\u5230\u5899\u89d2\uff0c\u7d27\u5f20\u5730\u89c2\u5bdf\u7740\u4ed6\u7684\u52a8\u9759\u3002\n\u8001\u5934\u8d70\u5230\u7a97\u8fb9\uff0c\u56db\u5904\u5f20\u671b\uff0c\u5374\u6ca1\u6709\u53d1\u73b0\u4efb\u4f55\u5f02\u5e38\u3002\u4ed6\u4f3c\u4e4e\u6709\u4e9b\u7591\u60d1\uff0c\u4f46\u5f88\u5feb\u53c8\u8f6c\u8fc7\u8eab\uff0c\u7ee7\u7eed\u5728\u623f\u95f4\u91cc\u8e31\u6b65\u3002\n\u6211\u677e\u4e86\u4e00\u53e3\u6c14\uff0c\u770b\u6765\u6211\u7684\u8ba1\u5212\u594f\u6548\u4e86\u3002\n\u6211\u6084\u6084\u5730\u8d70\u5230\u6742\u7269\u5806\u65c1\uff0c\u62ff\u8d77\u4e00\u6346\u7ef3\u5b50\uff0c\u5feb\u901f\u5730\u5728\u5c0f\u5c4b\u95e8\u53e3\u8bbe\u7f6e\u4e86\u4e00\u4e2a\u7b80\u5355\u7684\u7eca\u811a\u9677\u9631\u3002\u7136\u540e\uff0c\u6211\u518d\u6b21\u6361\u8d77\u4e00\u5757\u77f3\u5934\uff0c\u6254\u5411\u5c0f\u5c4b\u3002\n\u8fd9\u4e00\u6b21\uff0c\u8001\u5934\u5f84\u76f4\u671d\u7740\u95e8\u53e3\u8d70\u6765\u3002\u6211\u5c4f\u4f4f\u547c\u5438\uff0c\u63e1\u7d27\u624b\u4e2d\u7684\u6811\u679d\uff0c\u51c6\u5907\u8fce\u63a5\u5373\u5c06\u5230\u6765\u7684\u6218\u6597\u3002\n\u8001\u5934\u8d70\u5230\u95e8\u53e3\uff0c\u4e00\u811a\u8e29\u5728\u4e86\u7ef3\u5b50\u4e0a\u3002\u7ef3\u5b50\u731b\u5730\u7ef7\u7d27\uff0c\u4ed6\u7684\u811a\u88ab\u7eca\u4e86\u4e00\u4e0b\uff0c\u6574\u4e2a\u4eba\u5411\u524d\u6251\u5012\u3002\n\u201c\u5c31\u662f\u73b0\u5728\uff01\u201d\u6211\u5927\u558a\u4e00\u58f0\uff0c\u51b2\u4e0a\u524d\u53bb\uff0c\u4e3e\u8d77\u6811\u679d\uff0c\u671d\u7740\u8001\u5934\u7684\u5934\u90e8\u72e0\u72e0\u5730\u7838\u4e86\u4e0b\u53bb\u3002\n\u7136\u800c\uff0c\u5c31\u5728\u8fd9\u65f6\uff0c\u8001\u5934\u7a81\u7136\u4f38\u51fa\u624b\uff0c\u4e00\u628a\u6293\u4f4f\u4e86\u6211\u7684\u6811\u679d\u3002\u6211\u987f\u65f6\u4e00\u60ca\uff0c\u6ca1\u60f3\u5230\u4ed6\u53cd\u5e94\u5982\u6b64\u4e4b\u5feb\u3002\n\u8001\u5934\u731b\u5730\u7ad9\u8d77\u8eab\uff0c\u4e00\u628a\u5c06\u6211\u63a8\u5012\u5728\u5730\u3002\u6211\u624b\u4e2d\u7684\u6811\u679d\u4e5f\u6389\u843d\u5728\u4e00\u65c1\u3002\u6211\u60ca\u6050\u5730\u62ac\u5934\u770b\u7740\u4ed6\uff0c\u4ed6\u90a3\u5f20\u6ee1\u662f\u76b1\u7eb9\u7684\u8138\u6b64\u523b\u663e\u5f97\u5f02\u5e38\u72f0\u72de\uff0c\u773c\u4e2d\u5145\u6ee1\u4e86\u55dc\u8840\u7684\u5149\u8292\u3002\n\u6211\u610f\u8bc6\u5230\u81ea\u5df1\u72af\u4e86\u4e00\u4e2a\u9519\u8bef\uff0c\u6211\u4f4e\u4f30\u4e86\u4e27\u5c38\u7684\u529b\u91cf\u548c\u901f\u5ea6\u3002\n\u8001\u5934\u5f20\u5f00\u5634\uff0c\u9732\u51fa\u6cdb\u9ec4\u7684\u7259\u9f7f\uff0c\u671d\u7740\u6211\u7684\u8116\u5b50\u54ac\u6765\u3002\u6211\u7edd\u671b\u5730\u95ed\u4e0a\u773c\u775b\uff0c\u7b49\u5f85\u7740\u6b7b\u4ea1\u7684\u964d\u4e34\u3002\n\u7136\u800c\uff0c\u5c31\u5728\u8fd9\u65f6\uff0c\u6211\u611f\u89c9\u5230\u4e00\u80a1\u529b\u91cf\u5c06\u8001\u5934\u731b\u5730\u62c9\u5f00\u3002\u6211\u7741\u5f00\u773c\u775b\uff0c\u53d1\u73b0\u8001\u5934\u7684\u811a\u88ab\u6211\u4e4b\u524d\u8bbe\u7f6e\u7684\u7ef3\u7d22\u9677\u9631\u7f20\u4f4f\u4e86\u3002\u4ed6\u6323\u624e\u7740\u60f3\u8981\u6323\u8131\uff0c\u4f46\u5374\u65e0\u6d4e\u4e8e\u4e8b\u3002\n\u6211\u6293\u4f4f\u673a\u4f1a\uff0c \u9a6c\u4e0a\u722c\u8d77\u6765\uff0c\u6361\u8d77\u5730\u4e0a\u7684\u6811\u679d\uff0c\u518d\u6b21\u671d\u7740\u8001\u5934\u7838\u53bb\u3002\u8fd9\u4e00\u6b21\uff0c\u6211\u7784\u51c6\u4e86\u4ed6\u7684\u5934\u90e8\uff0c\u7528\u5c3d\u5168\u529b\u72e0\u72e0\u5730\u7838\u4e86\u4e0b\u53bb\u3002\n\u6811\u679d\u51fb\u4e2d\u4e86\u8001\u5934\u7684\u5934\u90e8\uff0c\u53d1\u51fa\u201c\u7830\u201d\u7684\u4e00\u58f0\u95f7\u54cd\u3002\u8001\u5934\u53d1\u51fa\u4e00\u58f0\u75db\u82e6\u7684\u568e\u53eb\uff0c\u8eab\u4f53\u731b\u5730\u62bd\u6410\u4e86\u4e00\u4e0b\uff0c\u7136\u540e\u4fbf\u4e00\u52a8\u4e0d\u52a8\u5730\u5012\u5728\u4e86\u5730\u4e0a\u3002\n\u6211\u6c14\u5598\u5401\u5401\u5730\u7ad9\u5728\u539f\u5730\uff0c\u770b\u7740\u5012\u5728\u5730\u4e0a\u7684\u8001\u5934\uff0c\u5fc3\u4e2d\u5145\u6ee1\u4e86\u6050\u60e7\u548c\u5174\u594b\u3002\u6211\u4e0d\u6562\u76f8\u4fe1\uff0c\u6211\u5c45\u7136\